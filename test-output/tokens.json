{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "blue": {
      "50": { "$value": "#EFF6FF", "$type": "color", "$description": "Lightest blue. Backgrounds, hover states." },
      "100": { "$value": "#DBEAFE", "$type": "color", "$description": "Light blue. Selected states, highlights." },
      "500": { "$value": "#3B82F6", "$type": "color", "$description": "Mid blue. Focus rings, active indicators." },
      "600": { "$value": "#2563EB", "$type": "color", "$description": "Primary blue. WCAG AA on white (5.17:1)." },
      "700": { "$value": "#1D4ED8", "$type": "color", "$description": "Dark blue. Hover state for primary actions." }
    },
    "gray": {
      "50": { "$value": "#F9FAFB", "$type": "color" },
      "100": { "$value": "#F3F4F6", "$type": "color" },
      "200": { "$value": "#E5E7EB", "$type": "color" },
      "300": { "$value": "#D1D5DB", "$type": "color" },
      "500": { "$value": "#6B7280", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "900": { "$value": "#111827", "$type": "color", "$description": "Near-black. WCAG AAA on white (17.74:1)." }
    },
    "white": { "$value": "#FFFFFF", "$type": "color" },
    "black": { "$value": "#000000", "$type": "color" }
  },
  "spacing": {
    "2xs": { "$value": "2px", "$type": "dimension" },
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "12px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" },
    "2xl": { "$value": "32px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "fontSize": {
    "xs": { "$value": "12px", "$type": "dimension" },
    "sm": { "$value": "14px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "18px", "$type": "dimension" },
    "xl": { "$value": "24px", "$type": "dimension" }
  },
  "size": {
    "touch-min-ios": { "$value": "44px", "$type": "dimension", "$description": "iOS HIG minimum touch target" },
    "touch-min-android": { "$value": "48px", "$type": "dimension", "$description": "Android Material minimum touch target" }
  }
}
